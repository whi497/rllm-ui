# ── rLLM UI Configuration ──────────────────────────────────────
# Copy to .env and fill in values. All variables are optional
# unless marked otherwise.

# ── Core ────────────────────────────────────────────────────────
# Anthropic API key — enables the built-in observability AI agent
ANTHROPIC_API_KEY=

# ── Database ────────────────────────────────────────────────────
# Default: SQLite (no config needed, data persisted in Docker volume)
# For PostgreSQL, uncomment:
# DATABASE_URL=postgresql://user:pass@host:5432/rllm_ui

# ── BigQuery (optional) ────────────────────────────────────────
# Set BQ_PROJECT to enable BigQuery trace reading.
# Auth: run `gcloud auth application-default login` on host,
# then use docker-compose.bigquery.yml overlay.
# BQ_PROJECT=my-gcp-project
# BQ_DATASET=agent_traces
# BQ_TABLE=rllm_traces

# For service account auth (alternative to ADC):
# GOOGLE_APPLICATION_CREDENTIALS=/gcp/sa-key.json
# GCP_SA_KEY_PATH=./path/to/your/sa-key.json

# ── Auth ────────────────────────────────────────────────────────
# JWT secret for session tokens. Default "local-dev-secret" is
# fine for local dev; set a real secret for any shared deployment.
# JWT_SECRET=local-dev-secret

# ── ClickHouse (optional) ──────────────────────────────────────
# CLICKHOUSE_HOST=
# CLICKHOUSE_PORT=8443
# CLICKHOUSE_USER=
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=default
# CLICKHOUSE_SECURE=true
